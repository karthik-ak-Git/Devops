<Window x:Class="DevOpsAIAgent.App.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:DevOpsAIAgent.App.ViewModels"
        mc:Ignorable="d"
        Title="DevOps AI Agent Dashboard" 
        Height="450" 
        Width="800"
        d:DataContext="{d:DesignInstance Type=viewModels:DashboardViewModel}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="DevOps AI Agent Dashboard" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Status: " FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text="Listening for webhooks on http://localhost:5000/cicd-webhook/" 
                       Foreground="Green" 
                       VerticalAlignment="Center"/>
        </StackPanel>

        <Separator Grid.Row="2" Margin="0,10"/>

        <TextBlock Grid.Row="3" 
                   Text="Last Pipeline Failure:" 
                   FontSize="18" 
                   FontWeight="SemiBold" 
                   Margin="0,10,0,10"/>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Repository:" FontWeight="Bold" Margin="0,5"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RepositoryName}" Margin="0,5"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Workflow:" FontWeight="Bold" Margin="0,5"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding WorkflowName}" Margin="0,5"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Commit Hash:" FontWeight="Bold" Margin="0,5"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LastFailedCommit}" Margin="0,5" FontFamily="Consolas"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Repository URL:" FontWeight="Bold" Margin="0,5"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,5">
                <Hyperlink NavigateUri="{Binding RepositoryUrl}" RequestNavigate="Hyperlink_RequestNavigate">
                    <TextBlock Text="{Binding RepositoryUrl}"/>
                </Hyperlink>
            </TextBlock>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Time:" FontWeight="Bold" Margin="0,5"/>
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LastFailureTime, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss} UTC'}" Margin="0,5"/>
        </Grid>

        <TextBlock Grid.Row="5" 
                   Text="💡 Waiting for GitHub Actions webhook notifications..." 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"
                   FontSize="14" 
                   Foreground="Gray"
                   Visibility="{Binding LastFailureTime, Converter={StaticResource NullToVisibilityConverter}}"/>
    </Grid>
</Window>
