{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information",
      "Microsoft.AspNetCore.SignalR": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.AspNetCore.SignalR": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "./logs/api-.log",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj} {Properties:j}{NewLine}{Exception}",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=devops_ai_agent;Username=postgres;Password=your_password_here"
  },
  "AllowedHosts": "*",
  "ApiSettings": {
    "Version": "1.0.0",
    "Title": "DevOps AI Agent API",
    "Description": "Comprehensive REST API for DevOps CI/CD monitoring, incident management, and AI-powered analysis",
    "RateLimiting": {
      "Enabled": true,
      "RequestsPerMinute": 100,
      "BurstSize": 20
    }
  },
  "LlmProviders": {
    "DefaultProvider": "Gemini",
    "EnableFallback": true,
    "TimeoutSeconds": 60,
    "Gemini": {
      "ApiKey": "${GEMINI_API_KEY}",
      "Model": "gemini-1.5-pro-latest",
      "Enabled": true,
      "MaxTokens": 8192,
      "Temperature": 0.3,
      "EmbeddingModel": "models/text-embedding-004"
    },
    "OpenRouter": {
      "ApiKey": "${OPENROUTER_API_KEY}",
      "BaseUrl": "https://openrouter.ai/api/v1",
      "Model": "anthropic/claude-3.5-sonnet",
      "Enabled": false,
      "MaxTokens": 8192,
      "Temperature": 0.3,
      "AppName": "DevOpsAIAgent"
    },
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "Model": "llama3.1:8b",
      "Enabled": false,
      "Temperature": 0.3,
      "KeepAlive": true
    }
  },
  "GitHub": {
    "Token": "${GITHUB_TOKEN}",
    "ApiUrl": "https://api.github.com",
    "WebhookSecret": "${GITHUB_WEBHOOK_SECRET}",
    "RateLimitRetries": 3,
    "TimeoutSeconds": 30
  },
  "SignalR": {
    "EnableDetailedErrors": false,
    "KeepAliveInterval": "00:00:15",
    "ClientTimeoutInterval": "00:00:30",
    "HandshakeTimeout": "00:00:15",
    "MaximumReceiveMessageSize": 32768,
    "StreamBufferCapacity": 10
  },
  "Dashboard": {
    "RefreshIntervalSeconds": 30,
    "MaxActivityItems": 100,
    "DefaultMetricsPeriodDays": 30,
    "CacheTimeoutMinutes": 5
  },
  "Webhooks": {
    "MaxPayloadSize": 1048576,
    "TimeoutSeconds": 30,
    "RetryAttempts": 3,
    "ValidEvents": ["workflow_run", "push", "pull_request", "deployment"]
  },
  "AI": {
    "AnalysisTimeout": 120,
    "EmbeddingBatchSize": 10,
    "SimilarityThreshold": 0.7,
    "MaxContextLength": 50000,
    "EnableEmbeddingCache": true
  },
  "Security": {
    "EnableApiKeyAuth": false,
    "RequireHttps": false,
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "https://localhost:5001"
    ],
    "EnableCors": true,
    "MaxRequestSize": 5242880
  },
  "HealthChecks": {
    "Enabled": true,
    "DetailedErrors": true,
    "CheckDatabaseConnection": true,
    "CheckExternalServices": false
  }
}