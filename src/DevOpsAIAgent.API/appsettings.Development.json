{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Information",
      "Microsoft.AspNetCore.SignalR": "Debug",
      "DevOpsAIAgent": "Debug"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=devops_ai_agent_dev;Username=postgres;Password=dev_password"
  },
  "ApiSettings": {
    "RateLimiting": {
      "Enabled": false,
      "RequestsPerMinute": 1000
    }
  },
  "LlmProviders": {
    "TimeoutSeconds": 120,
    "Gemini": {
      "Model": "gemini-1.5-pro-latest",
      "Temperature": 0.1,
      "MaxTokens": 8192
    }
  },
  "GitHub": {
    "TimeoutSeconds": 60,
    "RateLimitRetries": 5
  },
  "SignalR": {
    "EnableDetailedErrors": true,
    "KeepAliveInterval": "00:00:10",
    "ClientTimeoutInterval": "00:01:00",
    "MaximumReceiveMessageSize": 65536
  },
  "Dashboard": {
    "RefreshIntervalSeconds": 10,
    "CacheTimeoutMinutes": 1
  },
  "Webhooks": {
    "MaxPayloadSize": 2097152,
    "TimeoutSeconds": 60,
    "RetryAttempts": 5
  },
  "AI": {
    "AnalysisTimeout": 180,
    "EmbeddingBatchSize": 5,
    "SimilarityThreshold": 0.5,
    "EnableEmbeddingCache": false
  },
  "Security": {
    "RequireHttps": false,
    "EnableCors": true,
    "MaxRequestSize": 10485760
  },
  "HealthChecks": {
    "DetailedErrors": true,
    "CheckExternalServices": true
  }
}