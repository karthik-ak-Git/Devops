# DevOps AI Agent API Environment Configuration
# Copy this file to .env and update with your actual values

# ASP.NET Core Environment
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000;https://localhost:5001

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=devops_ai_agent
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# Google Gemini AI Configuration (Required)
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub Integration (Optional - improves API limits)
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# OpenRouter AI (Optional - alternative AI provider)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Ollama Configuration (Optional - local AI)
OLLAMA_BASE_URL=http://localhost:11434

# Security Configuration
JWT_SECRET_KEY=your_jwt_secret_key_here
API_KEY=your_api_key_here

# External Service URLs
WEBHOOK_BASE_URL=https://your-domain.com/api/webhooks

# Logging Configuration
LOG_LEVEL=Information
ENABLE_CONSOLE_LOGGING=true
ENABLE_FILE_LOGGING=true

# Performance Configuration
MAX_CONCURRENT_ANALYSES=5
EMBEDDING_BATCH_SIZE=10
REQUEST_TIMEOUT_SECONDS=30

# Feature Flags
ENABLE_RATE_LIMITING=false
ENABLE_AI_ANALYSIS=true
ENABLE_REAL_TIME_UPDATES=true
ENABLE_EMBEDDING_CACHE=true

# Development/Testing
MOCK_GITHUB_API=false
SKIP_WEBHOOK_VERIFICATION=false
ENABLE_DETAILED_ERRORS=true