@{
    ViewData["Title"] = "Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DevOps AI Agent - Live CI/CD Monitor</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Highlight.js for Syntax Highlighting -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">

    <!-- Custom Dark Theme Styles -->
    <style>
        :root {
            --bg-dark: #0d1117;
            --bg-darker: #010409;
            --bg-card: #161b22;
            --border-color: #30363d;
            --text-primary: #c9d1d9;
            --text-secondary: #8b949e;
            --accent-blue: #58a6ff;
            --accent-green: #3fb950;
            --accent-red: #f85149;
            --accent-yellow: #d29922;
            --hover-bg: #21262d;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-primary);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans", Helvetica, Arial, sans-serif;
            height: 100vh;
            overflow: hidden;
        }

        .navbar-custom {
            background: linear-gradient(135deg, #1a1e24 0%, #0d1117 100%);
            border-bottom: 2px solid var(--accent-blue);
            padding: 1rem 2rem;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
        }

        .navbar-brand {
            color: var(--text-primary) !important;
            font-size: 1.5rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .status-badge {
            display: inline-block;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background-color: var(--accent-green);
            animation: pulse 2s ease-in-out infinite;
        }

        @@keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        .main-container {
            height: calc(100vh - 80px);
            overflow: hidden;
        }

        /* Sidebar Styles */
        .sidebar {
            background-color: var(--bg-darker);
            border-right: 1px solid var(--border-color);
            height: 100%;
            overflow-y: auto;
            padding: 1.5rem;
        }

        .sidebar h5 {
            color: var(--accent-blue);
            font-size: 0.875rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 1rem;
            font-weight: 600;
        }

        .failure-card {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 1rem;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .failure-card:hover {
            background-color: var(--hover-bg);
            border-color: var(--accent-blue);
            transform: translateX(4px);
        }

        .failure-card.active {
            background-color: var(--hover-bg);
            border-color: var(--accent-blue);
            box-shadow: 0 0 0 2px rgba(88, 166, 255, 0.2);
        }

        .failure-card.new-arrival {
            animation: slideInLeft 0.5s ease-out, flashBorder 1.5s ease-in-out;
        }

        @@keyframes slideInLeft {
            from {
                transform: translateX(-20px);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        @@keyframes flashBorder {
            0%, 100% { border-color: var(--border-color); }
            50% { border-color: var(--accent-red); box-shadow: 0 0 10px rgba(248, 81, 73, 0.5); }
        }

        .failure-card-repo {
            color: var(--text-primary);
            font-weight: 600;
            font-size: 0.95rem;
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .failure-card-commit {
            color: var(--text-secondary);
            font-size: 0.8rem;
            font-family: 'Courier New', monospace;
        }

        .failure-card-time {
            color: var(--text-secondary);
            font-size: 0.75rem;
            margin-top: 0.5rem;
        }

        /* Main Content Styles */
        .main-content {
            height: 100%;
            overflow-y: auto;
            padding: 1.5rem 2rem;
        }

        .content-header {
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--border-color);
        }

        .content-header h4 {
            color: var(--text-primary);
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .content-header .meta {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        .content-section {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .content-section h5 {
            color: var(--accent-blue);
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .content-section pre {
            background-color: var(--bg-darker);
            border: 1px solid var(--border-color);
            border-radius: 6px;
            padding: 1rem;
            overflow-x: auto;
            margin: 0;
            max-height: 400px;
        }

        .content-section code {
            color: var(--text-primary);
            font-size: 0.85rem;
            line-height: 1.6;
        }

        /* Empty State */
        .empty-state {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 60vh;
            text-align: center;
        }

        .empty-state-icon {
            font-size: 4rem;
            color: var(--text-secondary);
            margin-bottom: 1.5rem;
            animation: float 3s ease-in-out infinite;
        }

        @@keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        .empty-state h3 {
            color: var(--text-primary);
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .empty-state p {
            color: var(--text-secondary);
            font-size: 0.95rem;
        }

        /* Badge Styles */
        .badge-failure {
            background-color: rgba(248, 81, 73, 0.2);
            color: var(--accent-red);
            border: 1px solid var(--accent-red);
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .badge-workflow {
            background-color: rgba(88, 166, 255, 0.2);
            color: var(--accent-blue);
            border: 1px solid var(--accent-blue);
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
            font-size: 0.75rem;
        }

        /* Scrollbar Styles */
        ::-webkit-scrollbar {
            width: 10px;
            height: 10px;
        }

        ::-webkit-scrollbar-track {
            background: var(--bg-darker);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--border-color);
            border-radius: 5px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--text-secondary);
        }

        /* Loading Spinner */
        .loading-spinner {
            display: inline-block;
            width: 1rem;
            height: 1rem;
            border: 2px solid var(--border-color);
            border-top-color: var(--accent-blue);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @@keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* AI Suggestion Specific Styles */
        .ai-suggestion-section {
            background: linear-gradient(135deg, rgba(88, 166, 255, 0.05) 0%, rgba(63, 185, 80, 0.05) 100%);
            border-left: 4px solid var(--accent-green);
        }

        .ai-suggestion-section h5 {
            color: var(--accent-green);
        }

        .markdown-content {
            color: var(--text-primary);
        }

        .markdown-content h2 {
            color: var(--accent-blue);
            font-size: 1.25rem;
            margin-top: 1.5rem;
            margin-bottom: 0.75rem;
            font-weight: 600;
        }

        .markdown-content h3 {
            color: var(--text-primary);
            font-size: 1.1rem;
            margin-top: 1rem;
            margin-bottom: 0.5rem;
        }

        .markdown-content pre {
            background-color: var(--bg-darker);
            border: 1px solid var(--border-color);
            border-radius: 6px;
            padding: 1rem;
            overflow-x: auto;
        }

        .markdown-content code {
            background-color: var(--bg-darker);
            padding: 0.2rem 0.4rem;
            border-radius: 3px;
            font-size: 0.9em;
        }

        .markdown-content pre code {
            background: none;
            padding: 0;
        }

        /* Link Styles */
        a {
            color: var(--accent-blue);
            text-decoration: none;
        }

        a:hover {
            color: var(--accent-blue);
            text-decoration: underline;
        }

        /* Button Styles */
        .btn-primary-custom {
            background-color: var(--accent-blue);
            border: none;
            color: var(--bg-dark);
            font-weight: 600;
            padding: 0.5rem 1rem;
            border-radius: 6px;
            transition: all 0.2s;
        }

        .btn-primary-custom:hover {
            background-color: #79c0ff;
            transform: translateY(-1px);
            box-shadow: 0 4px 8px rgba(88, 166, 255, 0.3);
        }

        /* Connection Status */
        .connection-status {
            font-size: 0.85rem;
            color: var(--text-secondary);
        }

        .connection-status.connected {
            color: var(--accent-green);
        }

        .connection-status.disconnected {
            color: var(--accent-red);
        }

        /* Repository List Styles */
        .repo-item {
            padding: 0.75rem 1rem;
            border-bottom: 1px solid var(--border-color);
            cursor: pointer;
            transition: all 0.2s;
        }

        .repo-item:last-child {
            border-bottom: none;
        }

        .repo-item:hover {
            background-color: var(--hover-bg);
        }

        .repo-item.selected {
            background-color: var(--hover-bg);
            border-left: 3px solid var(--accent-blue);
        }

        .repo-item-name {
            color: var(--text-primary);
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 0.25rem;
        }

        .repo-item-desc {
            color: var(--text-secondary);
            font-size: 0.8rem;
            margin-bottom: 0.25rem;
        }

        .repo-item-badges {
            display: flex;
            gap: 0.5rem;
            margin-top: 0.5rem;
        }

        .repo-badge {
            font-size: 0.7rem;
            padding: 0.2rem 0.5rem;
            border-radius: 3px;
            font-weight: 600;
        }

        .repo-badge-private {
            background-color: rgba(210, 153, 34, 0.2);
            color: var(--accent-yellow);
            border: 1px solid var(--accent-yellow);
        }

        .repo-badge-configured {
            background-color: rgba(63, 185, 80, 0.2);
            color: var(--accent-green);
            border: 1px solid var(--accent-green);
        }

        /* Logs Panel Styles */
        #failuresPanel, #logsPanel {
            display: none;
        }

        #failuresPanel.active, #logsPanel.active {
            display: block;
        }

        #logsPanel {
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        #logsList {
            flex: 1;
            overflow-y: auto;
            font-family: 'Courier New', monospace;
            font-size: 0.8rem;
            background-color: var(--bg-darker);
            border: 1px solid var(--border-color);
            border-radius: 6px;
            padding: 0.75rem;
        }

        .log-entry {
            margin-bottom: 0.5rem;
            padding: 0.5rem;
            border-radius: 4px;
            font-size: 0.75rem;
        }

        .log-entry.info {
            color: var(--accent-blue);
        }

        .log-entry.success {
            color: var(--accent-green);
        }

        .log-entry.warning {
            color: var(--accent-yellow);
        }

        .log-entry.error {
            color: var(--accent-red);
        }

        .log-time {
            color: var(--text-secondary);
            margin-right: 0.5rem;
        }
    </style>
</head>
<body>
    <!-- Top Navbar -->
    <nav class="navbar navbar-custom">
        <div class="container-fluid">
            <span class="navbar-brand">
                <span class="status-badge"></span>
                DevOps AI Agent - Live CI/CD Monitor
            </span>
            <span class="connection-status" id="connectionStatus">
                <span class="loading-spinner"></span> Connecting...
            </span>
        </div>
    </nav>

    <!-- Main Container -->
    <div class="container-fluid main-container">
        <div class="row h-100">
            <!-- Left Sidebar: Recent Failures & Logs -->
            <div class="col-md-3 sidebar">
                <!-- Tabs for switching between Failures and Logs -->
                <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
                    <button onclick="switchSidebarTab('failures')" id="failuresTab" style="flex: 1; padding: 0.5rem; background: var(--border-color); color: var(--text-primary); border: none; border-radius: 4px; cursor: pointer; font-weight: 600; font-size: 0.85rem;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" style="margin-right: 0.3rem;">
                            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                        </svg>
                        Failures
                    </button>
                    <button onclick="switchSidebarTab('logs')" id="logsTab" style="flex: 1; padding: 0.5rem; background: transparent; color: var(--text-secondary); border: none; border-radius: 4px; cursor: pointer; font-weight: 600; font-size: 0.85rem;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" style="margin-right: 0.3rem;">
                            <path d="M4 .5a.5.5 0 0 0-.5.5v12a.5.5 0 0 0 .5.5h8a.5.5 0 0 0 .5-.5V.5a.5.5 0 0 0-.5-.5H4zm0 1h8v12H4V1.5z"/>
                        </svg>
                        Logs
                    </button>
                </div>

                <!-- Failures Tab -->
                <div id="failuresPanel">
                    <h5>
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                            <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 4.995z"/>
                        </svg>
                        Recent Failures (<span id="failureCount">0</span>)
                    </h5>
                    <div id="failureList"></div>
                    <div id="emptyState" class="empty-state">
                    <div class="empty-state-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872l-.1-.34zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z"/>
                        </svg>
                    </div>
                    <h3>Waiting for CI/CD Webhooks...</h3>
                    <p>Connect your GitHub repository webhooks to start monitoring pipeline failures in real-time.</p>

                    <!-- Webhook Configuration Form -->
                    <div class="mt-4" style="max-width: 600px; margin-left: auto; margin-right: auto;">
                        <div style="background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 8px; padding: 2rem;">
                            <h5 style="color: var(--accent-blue); margin-bottom: 1rem; font-size: 1rem;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" style="margin-right: 0.5rem;">
                                    <path d="M8 0a1 1 0 0 1 1 1v6h6a1 1 0 1 1 0 2H9v6a1 1 0 1 1-2 0V9H1a1 1 0 0 1 0-2h6V1a1 1 0 0 1 1-1z"/>
                                </svg>
                                Configure Webhook for Repository
                            </h5>

                            <div class="mb-3">
                                <button class="btn btn-primary-custom w-100" onclick="loadUserRepositories()" id="loadReposBtn">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" style="margin-right: 0.5rem;">
                                        <path d="M2 2.5a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 0 1H3v10.5a.5.5 0 0 1-.5.5h-.5a.5.5 0 0 1-.5-.5V3H.5a.5.5 0 0 1 0-1h1.5V2.5zm10.5 0A.5.5 0 0 1 13 2h3a.5.5 0 0 1 0 1h-1.5v10.5a.5.5 0 0 1-.5.5h-.5a.5.5 0 0 1-.5-.5V3H12a.5.5 0 0 1 0-1h.5v-.5z"/>
                                        <path fill-rule="evenodd" d="M8 3a.5.5 0 0 1 .5.5v9a.5.5 0 0 1-1 0v-9A.5.5 0 0 1 8 3z"/>
                                    </svg>
                                    Load My Repositories
                                </button>
                            </div>

                            <div id="repoSelectorContainer" style="display: none;">
                                <div class="mb-3">
                                    <label for="repoSearch" style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-bottom: 0.5rem;">
                                        Search Repositories
                                    </label>
                                    <input type="text" id="repoSearch" placeholder="Type to filter repositories..." 
                                           oninput="filterRepositories()"
                                           style="width: 100%; padding: 0.6rem; background: var(--bg-darker); border: 1px solid var(--border-color); border-radius: 6px; color: var(--text-primary); font-size: 0.9rem;">
                                </div>

                                <div class="mb-3">
                                    <label for="repoDropdown" style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-bottom: 0.5rem;">
                                        Select Repository (<span id="repoCountText">0</span> available)
                                    </label>
                                    <select id="repoDropdown" onchange="selectRepositoryFromDropdown()"
                                            style="width: 100%; padding: 0.7rem; background: var(--bg-darker); border: 1px solid var(--border-color); border-radius: 6px; color: var(--text-primary); font-size: 0.9rem; cursor: pointer;">
                                        <option value="" style="color: var(--text-secondary);">-- Choose a repository --</option>
                                    </select>
                                </div>

                                <div class="mb-3" id="selectedRepoInfo" style="display: none; padding: 1rem; background: var(--hover-bg); border: 1px solid var(--accent-blue); border-radius: 6px;">
                                    <div style="color: var(--accent-blue); font-weight: 600; margin-bottom: 0.5rem;" id="selectedRepoName"></div>
                                    <div style="color: var(--text-secondary); font-size: 0.85rem;" id="selectedRepoDesc"></div>
                                    <div style="margin-top: 0.5rem;" id="selectedRepoBadges"></div>
                                </div>

                                <div class="mb-3" id="webhookNameSection" style="display: none;">
                                    <label for="webhookName" style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-bottom: 0.5rem;">
                                        Webhook Name (Auto-generated)
                                    </label>
                                    <input type="text" id="webhookName" readonly
                                           style="width: 100%; padding: 0.6rem; background: var(--bg-darker); border: 1px solid var(--border-color); border-radius: 6px; color: var(--text-secondary); font-size: 0.9rem;">
                                </div>

                                <div class="mb-3" id="webhookUrlSection" style="display: none;">
                                    <label for="webhookUrl" style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-bottom: 0.5rem;">
                                        Webhook URL
                                        <span style="color: var(--accent-green); font-weight: 600; margin-left: 0.5rem; font-size: 0.75rem;">Auto-configured</span>
                                    </label>
                                    <input type="text" id="webhookUrl" placeholder="Auto-detected from ngrok or server URL"
                                           style="width: 100%; padding: 0.6rem; background: var(--bg-darker); border: 1px solid var(--border-color); border-radius: 6px; color: var(--text-secondary); font-size: 0.9rem;" readonly>
                                    <small style="display: block; margin-top: 0.3rem; color: var(--text-secondary); font-size: 0.75rem;">
                                        Automatically configured. To use custom URL, edit the field below.
                                    </small>
                                </div>

                                <div class="mb-3" id="webhookEventsSection" style="display: none;">
                                    <label style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-bottom: 0.5rem;">
                                        Webhook Events
                                    </label>
                                    <div style="display: flex; gap: 1rem; padding: 0.5rem; background: var(--bg-darker); border: 1px solid var(--border-color); border-radius: 6px;">
                                        <label style="display: flex; align-items: center; color: var(--text-primary); font-size: 0.85rem; cursor: pointer;">
                                            <input type="checkbox" id="eventPush" checked style="margin-right: 0.5rem; cursor: pointer;">
                                            Push
                                        </label>
                                        <label style="display: flex; align-items: center; color: var(--text-primary); font-size: 0.85rem; cursor: pointer;">
                                            <input type="checkbox" id="eventWorkflowRun" checked style="margin-right: 0.5rem; cursor: pointer;">
                                            Workflow Run
                                        </label>
                                    </div>
                                </div>

                                <div id="webhookConfigStatus" style="margin-bottom: 1rem; display: none; padding: 0.75rem; border-radius: 6px; font-size: 0.85rem;"></div>

                                <button class="btn btn-primary-custom w-100" onclick="configureWebhook()" id="configureWebhookBtn" disabled>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" style="margin-right: 0.5rem;">
                                        <path d="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492zM5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0z"/>
                                        <path d="M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52l-.094-.319zm-2.633.283c.246-.835 1.428-.835 1.674 0l.094.319a1.873 1.873 0 0 0 2.693 1.115l.291-.16c.764-.415 1.6.42 1.184 1.185l-.159.292a1.873 1.873 0 0 0 1.116 2.692l.318.094c.835.246.835 1.428 0 1.674l-.319.094a1.873 1.873 0 0 0-1.115 2.693l.16.291c.415.764-.42 1.6-1.185 1.184l-.291-.159a1.873 1.873 0 0 0-2.693 1.116l-.094.318c-.246.835-1.428.835-1.674 0l-.094-.319a1.873 1.873 0 0 0-2.692-1.115l-.292.16c-.764.415-1.6-.42-1.184-1.185l.159-.291A1.873 1.873 0 0 0 1.945 8.93l-.319-.094c-.835-.246-.835-1.428 0-1.674l.319-.094A1.873 1.873 0 0 0 3.06 4.377l-.16-.292c-.415-.764.42-1.6 1.185-1.184l.292.159a1.873 1.873 0 0 0 2.692-1.115l.094-.319z"/>
                                    </svg>
                                    Configure Webhook
                                </button>
                            </div>

                            <div class="mt-3" style="padding: 1rem; background: rgba(88, 166, 255, 0.1); border: 1px solid var(--accent-blue); border-radius: 6px;">
                                <p style="font-size: 0.85rem; color: var(--text-primary); margin-bottom: 0.5rem; font-weight: 600;">
                                    📋 Required Permissions:
                                </p>
                                <ul style="font-size: 0.8rem; color: var(--text-secondary); margin: 0; padding-left: 1.5rem;">
                                    <li>Repository admin access</li>
                                    <li>GitHub token with <code style="background: var(--bg-darker); padding: 0.2rem 0.4rem; border-radius: 3px;">repo</code> scope</li>
                                    <li>GitHub token with <code style="background: var(--bg-darker); padding: 0.2rem 0.4rem; border-radius: 3px;">admin:repo_hook</code> scope</li>
                                </ul>
                            </div>

                            <p class="mt-3 mb-0" style="font-size: 0.75rem; color: var(--text-secondary); text-align: center;">
                                Webhook will monitor <strong>Workflow Run</strong> events for pipeline failures
                            </p>
                        </div>
                    </div>
                </div>

                <div id="detailsView" style="display: none;">
                    <!-- Content Header -->
                    <div class="content-header">
                        <h4 id="detailRepo">Repository Name</h4>
                        <div class="meta">
                            <span class="badge-failure">FAILED</span>
                            <span class="badge-workflow" id="detailWorkflow">Workflow Name</span>
                            <span style="margin: 0 0.5rem;">•</span>
                            <span>Commit: <code id="detailCommit" style="color: var(--accent-blue);">abc123</code></span>
                            <span style="margin: 0 0.5rem;">•</span>
                            <a href="#" id="detailRunUrl" target="_blank" style="color: var(--accent-blue);">View Run</a>
                            <span style="margin: 0 0.5rem;">•</span>
                            <span id="detailTime">Just now</span>
                        </div>
                    </div>

                    <!-- Git Diff Section -->
                    <div class="content-section">
                        <h5>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2v1z"/>
                                <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z"/>
                            </svg>
                            Git Diff & Error Log
                        </h5>
                        <pre><code id="detailDiff" class="language-diff">Loading...</code></pre>
                    </div>

                    <!-- AI Suggestion Section -->
                    <div class="content-section ai-suggestion-section">
                        <h5>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M5 2V0H0v5h2v6H0v5h5v-2h6v2h5v-5h-2V5h2V0h-5v2H5zm6 1v2h2v6h-2v2H5v-2H3V5h2V3h6z"/>
                            </svg>
                            AI-Powered Fix Suggestion
                            <span class="loading-spinner" id="aiLoadingSpinner" style="display: none;"></span>
                        </h5>
                        <div id="detailAiSuggestion" class="markdown-content">
                            Analyzing failure...
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="text-end">
                        <button class="btn btn-primary-custom" onclick="copyToClipboard()">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1v-1z"/>
                                <path d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5h3zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3z"/>
                            </svg>
                            Copy AI Suggestion
                        </button>
                    </div>
                </div>

                <!-- Logs Panel -->
                <div id="logsPanel">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                        <h5 style="margin: 0;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M4 .5a.5.5 0 0 0-.5.5v12a.5.5 0 0 0 .5.5h8a.5.5 0 0 0 .5-.5V.5a.5.5 0 0 0-.5-.5H4zm0 1h8v12H4V1.5z"/>
                            </svg>
                            System Logs
                        </h5>
                        <button onclick="clearLogs()" style="background: var(--accent-red); color: white; border: none; padding: 0.3rem 0.6rem; border-radius: 4px; font-size: 0.75rem; cursor: pointer;">Clear</button>
                    </div>
                    <div id="logsList"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Highlight.js for Syntax Highlighting -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/diff.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/csharp.min.js"></script>

    <!-- Marked.js for Markdown Rendering -->
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

    <!-- SignalR Client -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>

    <!-- Dashboard Logic -->
    <script>
        let failures = [];
        let selectedFailureId = null;
        let connection = null;
        let logs = [];

        // Logging function
        function addLog(message, type = 'info') {
            const timestamp = new Date().toLocaleTimeString();
            logs.push({ timestamp, message, type });

            // Keep only last 100 logs
            if (logs.length > 100) {
                logs.shift();
            }

            // Add to UI
            const logsList = document.getElementById("logsList");
            const logEntry = document.createElement('div');
            logEntry.className = `log-entry ${type}`;
            logEntry.innerHTML = `<span class="log-time">[${timestamp}]</span>${message}`;
            logsList.appendChild(logEntry);
            logsList.scrollTop = logsList.scrollHeight;
        }

        function clearLogs() {
            logs = [];
            document.getElementById("logsList").innerHTML = '';
            addLog("Logs cleared", 'info');
        }

        function switchSidebarTab(tab) {
            // Hide all panels
            document.getElementById("failuresPanel").classList.remove("active");
            document.getElementById("logsPanel").classList.remove("active");

            // Hide all tab buttons background
            document.getElementById("failuresTab").style.background = "transparent";
            document.getElementById("failuresTab").style.color = "var(--text-secondary)";
            document.getElementById("logsTab").style.background = "transparent";
            document.getElementById("logsTab").style.color = "var(--text-secondary)";

            // Show selected tab
            if (tab === 'failures') {
                document.getElementById("failuresPanel").classList.add("active");
                document.getElementById("failuresTab").style.background = "var(--border-color)";
                document.getElementById("failuresTab").style.color = "var(--text-primary)";
            } else if (tab === 'logs') {
                document.getElementById("logsPanel").classList.add("active");
                document.getElementById("logsTab").style.background = "var(--border-color)";
                document.getElementById("logsTab").style.color = "var(--text-primary)";
            }
        }

        // Initialize failures panel as active
        document.addEventListener("DOMContentLoaded", function() {
            document.getElementById("failuresPanel").classList.add("active");
            document.getElementById("failuresTab").style.background = "var(--border-color)";
            document.getElementById("failuresTab").style.color = "var(--text-primary)";
            addLog("Dashboard initialized", "info");
        });

        // Initialize SignalR Connection
        async function initializeSignalR() {
            try {
                addLog("Connecting to SignalR...", "info");
                // Use absolute URL with correct hub path
                const hubUrl = `${window.location.origin}/api/hubs/dashboard`;

                connection = new signalR.HubConnectionBuilder()
                    .withUrl(hubUrl)
                    .withAutomaticReconnect()
                    .configureLogging(signalR.LogLevel.Information)
                    .build();

                // Handle incoming pipeline failures
                connection.on("ReceivePipelineFailure", function (payload) {
                    addLog(`Received pipeline failure from ${payload.Repo}`, "error");
                    handleNewFailure(payload);
                });

                // Connection state handlers
                connection.onreconnecting(() => {
                    updateConnectionStatus("Reconnecting...", false);
                    addLog("SignalR reconnecting...", "warning");
                });

                connection.onreconnected(() => {
                    updateConnectionStatus("Connected", true);
                    addLog("SignalR reconnected", "success");
                });

                connection.onclose(() => {
                    updateConnectionStatus("Disconnected", false);
                    addLog("SignalR disconnected, retrying in 5s...", "warning");
                    setTimeout(() => initializeSignalR(), 5000);
                });

                await connection.start();
                updateConnectionStatus("Connected", true);
                addLog("SignalR connected successfully", "success");
            } catch (err) {
                addLog(`SignalR connection error: ${err.message}`, "error");
                updateConnectionStatus("Connection Failed", false);
                setTimeout(() => initializeSignalR(), 5000);
            }
        }

        // Update connection status indicator
        function updateConnectionStatus(message, isConnected) {
            const statusElement = document.getElementById("connectionStatus");
            statusElement.className = isConnected ? "connection-status connected" : "connection-status disconnected";
            statusElement.innerHTML = isConnected 
                ? `<span style="display: inline-block; width: 8px; height: 8px; background: var(--accent-green); border-radius: 50%; margin-right: 0.5rem;"></span>${message}`
                : `<span style="display: inline-block; width: 8px; height: 8px; background: var(--accent-red); border-radius: 50%; margin-right: 0.5rem;"></span>${message}`;
        }

        // Handle new failure from SignalR
        function handleNewFailure(payload) {
            const failure = {
                id: Date.now(),
                repo: payload.repo || payload.Repo,
                repoUrl: payload.repoUrl || payload.RepoUrl,
                commitHash: payload.commitHash || payload.CommitHash,
                workflowName: payload.workflowName || payload.WorkflowName,
                runUrl: payload.runUrl || payload.RunUrl,
                runId: payload.runId || payload.RunId,
                gitDiff: payload.gitDiff || payload.GitDiff,
                errorLog: payload.errorLog || payload.ErrorLog,
                aiSuggestion: payload.aiSuggestion || payload.AiSuggestion,
                timestamp: new Date(payload.timestamp || payload.Timestamp)
            };

            failures.unshift(failure);
            renderFailureList();

            // Auto-select the new failure
            selectFailure(failure.id);

            // Flash notification
            showNotification(`New failure detected in ${failure.repo}`);
        }

        // Render the failure list in sidebar
        function renderFailureList() {
            const listElement = document.getElementById("failureList");
            const countElement = document.getElementById("failureCount");

            countElement.textContent = failures.length;

            if (failures.length === 0) {
                listElement.innerHTML = '<p style="color: var(--text-secondary); font-size: 0.85rem;">No failures yet...</p>';
                return;
            }

            listElement.innerHTML = failures.map((failure, index) => `
                <div class="failure-card ${index === 0 ? 'new-arrival' : ''} ${failure.id === selectedFailureId ? 'active' : ''}" 
                     onclick="selectFailure(${failure.id})">
                    <div class="failure-card-repo">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="var(--accent-red)" viewBox="0 0 16 16">
                            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                            <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 4.995z"/>
                        </svg>
                        ${escapeHtml(failure.repo)}
                    </div>
                    <div class="failure-card-commit">
                        ${escapeHtml(failure.commitHash.substring(0, 7))}
                    </div>
                    <div class="failure-card-time">
                        ${getTimeAgo(failure.timestamp)}
                    </div>
                </div>
            `).join('');
        }

        // Select and display a failure
        function selectFailure(failureId) {
            selectedFailureId = failureId;
            const failure = failures.find(f => f.id === failureId);

            if (!failure) return;

            // Hide empty state, show details
            document.getElementById("emptyState").style.display = "none";
            document.getElementById("detailsView").style.display = "block";

            // Update header
            document.getElementById("detailRepo").innerHTML = `
                <a href="${escapeHtml(failure.repoUrl)}" target="_blank" style="color: var(--text-primary);">
                    ${escapeHtml(failure.repo)}
                </a>
            `;
            document.getElementById("detailWorkflow").textContent = failure.workflowName;
            document.getElementById("detailCommit").textContent = failure.commitHash.substring(0, 7);
            document.getElementById("detailRunUrl").href = failure.runUrl;
            document.getElementById("detailTime").textContent = getTimeAgo(failure.timestamp);

            // Update Git Diff (combine diff and error log)
            const combinedLog = `${failure.gitDiff}\n\n${"=".repeat(80)}\nERROR LOG\n${"=".repeat(80)}\n\n${failure.errorLog}`;
            document.getElementById("detailDiff").textContent = combinedLog;

            // Update AI Suggestion
            const aiElement = document.getElementById("detailAiSuggestion");
            if (failure.aiSuggestion) {
                aiElement.innerHTML = marked.parse(failure.aiSuggestion);
                // Apply syntax highlighting to code blocks
                aiElement.querySelectorAll('pre code').forEach((block) => {
                    hljs.highlightElement(block);
                });
            } else {
                aiElement.innerHTML = '<p style="color: var(--text-secondary);">AI analysis not available</p>';
            }

            // Apply syntax highlighting
            hljs.highlightElement(document.getElementById("detailDiff"));

            // Update active state in sidebar
            renderFailureList();
        }

        // Utility: Escape HTML
        function escapeHtml(unsafe) {
            if (!unsafe) return '';
            return unsafe
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        // Utility: Time ago formatter
        function getTimeAgo(date) {
            const seconds = Math.floor((new Date() - date) / 1000);

            if (seconds < 60) return "Just now";
            if (seconds < 3600) return `${Math.floor(seconds / 60)}m ago`;
            if (seconds < 86400) return `${Math.floor(seconds / 3600)}h ago`;
            return `${Math.floor(seconds / 86400)}d ago`;
        }

        // Utility: Show notification
        function showNotification(message) {
            // You can integrate toast notifications here
            console.log("Notification:", message);
        }

        // Copy AI suggestion to clipboard
        function copyToClipboard() {
            const failure = failures.find(f => f.id === selectedFailureId);
            if (!failure || !failure.aiSuggestion) return;

            navigator.clipboard.writeText(failure.aiSuggestion).then(() => {
                showNotification("AI suggestion copied to clipboard!");
                // Visual feedback
                const btn = event.target.closest('button');
                const originalText = btn.innerHTML;
                btn.innerHTML = '✓ Copied!';
                setTimeout(() => {
                    btn.innerHTML = originalText;
                }, 2000);
            }).catch(err => {
                console.error("Failed to copy:", err);
            });
        }

        // Configure webhook for a repository
        let allRepositories = [];
        let selectedRepository = null;

        // Load user repositories from GitHub
        async function loadUserRepositories() {
            const btn = document.getElementById("loadReposBtn");
            const repoContainer = document.getElementById("repoSelectorContainer");
            const statusDiv = document.getElementById("webhookConfigStatus");

            // Show loading state
            const originalBtnText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="loading-spinner"></span> Loading repositories...';
            statusDiv.style.display = "none";

            try {
                console.log("Fetching user repositories...");

                // Use absolute URL
                const apiUrl = `${window.location.origin}/api/webhooks/repositories`;
                const response = await fetch(apiUrl);
                const result = await response.json();

                if (response.ok) {
                    // Check if configuration is required
                    if (result.configurationRequired) {
                        showWebhookStatus(result.message + " See CONFIGURATION_SETUP.md for instructions.", false);
                        return;
                    }

                    if (!result.success || result.count === 0) {
                        allRepositories = [];
                        showWebhookStatus("No repositories found with admin access. You need admin rights to configure webhooks.", false);
                        return;
                    }

                    allRepositories = result.repositories || [];

                    if (allRepositories.length === 0) {
                        showWebhookStatus("No repositories found with admin access. You need admin rights to configure webhooks.", false);
                        return;
                    }

                    console.log(`Loaded ${allRepositories.length} repositories`);

                    // Hide load button, show selector
                    btn.style.display = "none";
                    repoContainer.style.display = "block";

                    // Render repository list
                    renderRepositoryList(allRepositories);
                } else {
                    showWebhookStatus(`Error: ${result.message}`, false);
                }
            } catch (error) {
                console.error("Error loading repositories:", error);
                showWebhookStatus(`Error loading repositories: ${error.message}`, false);
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalBtnText;
            }
        }

        // Render repository list in dropdown
        function renderRepositoryList(repos) {
            const repoDropdown = document.getElementById("repoDropdown");
            const repoCountText = document.getElementById("repoCountText");

            repoCountText.textContent = repos.length;

            // Clear existing options except the first one
            repoDropdown.innerHTML = '<option value="" style="color: var(--text-secondary);">-- Choose a repository --</option>';

            if (repos.length === 0) {
                repoDropdown.innerHTML += '<option value="" disabled>No repositories found</option>';
                return;
            }

            // Add repository options
            repos.forEach(repo => {
                const option = document.createElement('option');
                option.value = repo.fullName;
                option.textContent = `${repo.fullName}${repo.isPrivate ? ' 🔒' : ''}${repo.hasWebhook ? ' ✓' : ''}`;
                option.dataset.repo = JSON.stringify(repo);
                repoDropdown.appendChild(option);
            });
        }

        // Filter repositories based on search
        function filterRepositories() {
            const searchText = document.getElementById("repoSearch").value.toLowerCase();
            const filteredRepos = allRepositories.filter(repo => 
                repo.fullName.toLowerCase().includes(searchText) ||
                (repo.description && repo.description.toLowerCase().includes(searchText))
            );
            renderRepositoryList(filteredRepos);

            // Reset selection if current selected repo is filtered out
            if (selectedRepository && !filteredRepos.find(r => r.fullName === selectedRepository.fullName)) {
                selectedRepository = null;
                document.getElementById("selectedRepoInfo").style.display = "none";
                document.getElementById("webhookNameSection").style.display = "none";
                document.getElementById("configureWebhookBtn").disabled = true;
            }
        }

        // Select a repository from dropdown
        function selectRepositoryFromDropdown() {
            const dropdown = document.getElementById("repoDropdown");
            const fullName = dropdown.value;

            if (!fullName) {
                // No selection
                selectedRepository = null;
                document.getElementById("selectedRepoInfo").style.display = "none";
                document.getElementById("webhookNameSection").style.display = "none";
                document.getElementById("configureWebhookBtn").disabled = true;
                document.getElementById("webhookConfigStatus").style.display = "none";
                return;
            }

            // Get the repository data from the selected option
            const selectedOption = dropdown.options[dropdown.selectedIndex];
            selectedRepository = JSON.parse(selectedOption.dataset.repo);

            console.log("Selected repository:", selectedRepository);

            // Show repository info
            const infoDiv = document.getElementById("selectedRepoInfo");
            infoDiv.style.display = "block";

            document.getElementById("selectedRepoName").textContent = selectedRepository.fullName;
            document.getElementById("selectedRepoDesc").textContent = selectedRepository.description || "No description";

            // Show badges
            let badgesHtml = '';
            if (selectedRepository.isPrivate) {
                badgesHtml += '<span class="repo-badge repo-badge-private">🔒 PRIVATE</span> ';
            }
            if (selectedRepository.hasWebhook) {
                badgesHtml += '<span class="repo-badge repo-badge-configured">✓ WEBHOOK CONFIGURED</span>';
            }
            document.getElementById("selectedRepoBadges").innerHTML = badgesHtml;

            // Generate webhook name
            const webhookName = `DevOps-AI-Agent-${new Date().toISOString().replace(/[:.]/g, '-').substring(0, 19)}`;
            document.getElementById("webhookName").value = webhookName;
            document.getElementById("webhookNameSection").style.display = "block";

            // Show webhook URL input
            const webhookUrlInput = document.getElementById("webhookUrl");
            const currentUrl = `${window.location.origin}/api/webhooks/github`;

            // Auto-fill webhook URL
            webhookUrlInput.value = currentUrl;
            addLog(`Webhook URL set to: ${currentUrl}`, "info");

            document.getElementById("webhookUrlSection").style.display = "block";
            document.getElementById("webhookEventsSection").style.display = "block";

            // Enable configure button
            document.getElementById("configureWebhookBtn").disabled = false;

            // Clear previous status
            document.getElementById("webhookConfigStatus").style.display = "none";
        }

        // Configure webhook for selected repository
        async function configureWebhook() {
            if (!selectedRepository) {
                showWebhookStatus("Please select a repository first", false);
                return;
            }

            const statusDiv = document.getElementById("webhookConfigStatus");
            const btn = document.getElementById("configureWebhookBtn");
            const webhookUrlInput = document.getElementById("webhookUrl");
            let webhookUrl = webhookUrlInput.value.trim();

            // Validate webhook URL
            if (!webhookUrl) {
                webhookUrl = `${window.location.origin}/api/webhooks/github`;

                // Check if using localhost
                if (webhookUrl.includes("localhost") || webhookUrl.includes("127.0.0.1")) {
                    showWebhookStatus("⚠️ Webhook URL cannot be localhost. Please:\n1. Download ngrok: https://ngrok.com/download\n2. Run: ngrok http 5120\n3. Copy the ngrok URL (e.g., https://abc123.ngrok.io)\n4. Paste it in the Webhook URL field\n5. Try again", false);
                    return;
                }
            }

            // Validate URL format
            if (!webhookUrl.startsWith("https://") && !webhookUrl.startsWith("http://")) {
                showWebhookStatus("Invalid webhook URL format. Must start with http:// or https://", false);
                return;
            }

            // Show loading state
            const originalBtnText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="loading-spinner"></span> Configuring webhook...';
            statusDiv.style.display = "none";

            try {
                console.log(`Configuring webhook for ${selectedRepository.fullName} with URL: ${webhookUrl}`);

                // Collect selected webhook events
                const events = [];
                const pushCheckbox = document.getElementById("eventPush");
                const workflowCheckbox = document.getElementById("eventWorkflowRun");

                if (pushCheckbox && pushCheckbox.checked) {
                    events.push("push");
                }
                if (workflowCheckbox && workflowCheckbox.checked) {
                    events.push("workflow_run");
                }

                // Default to workflow_run if none selected
                if (events.length === 0) {
                    events.push("workflow_run");
                }

                addLog(`Webhook events selected: ${events.join(", ")}`, "info");

                // Use absolute URL
                const apiUrl = `${window.location.origin}/api/webhooks/configure`;
                const response = await fetch(apiUrl, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        fullName: selectedRepository.fullName,
                        webhookUrl: webhookUrl,
                        events: events
                    })
                });

                const result = await response.json();

                if (response.ok && result.success) {
                    showWebhookStatus(result.message, true);
                    console.log("Webhook configured:", result);

                    // Update repository status
                    selectedRepository.hasWebhook = true;

                    // Update the dropdown option to show checkmark
                    const dropdown = document.getElementById("repoDropdown");
                    const selectedOption = dropdown.options[dropdown.selectedIndex];
                    selectedOption.textContent = `${selectedRepository.fullName}${selectedRepository.isPrivate ? ' 🔒' : ''} ✓`;

                    // Clear selection after short delay
                    setTimeout(() => {
                        selectedRepository = null;
                        dropdown.value = "";
                        document.getElementById("selectedRepoInfo").style.display = "none";
                        document.getElementById("webhookNameSection").style.display = "none";
                        document.getElementById("webhookUrlSection").style.display = "none";
                        document.getElementById("configureWebhookBtn").disabled = true;
                    }, 3000);
                } else {
                    showWebhookStatus(result.message, false);
                    console.error("Webhook configuration failed:", result);
                }
            } catch (error) {
                console.error("Error configuring webhook:", error);
                showWebhookStatus(`Error: ${error.message}`, false);
            } finally {
                btn.disabled = selectedRepository === null;
                btn.innerHTML = originalBtnText;
            }
        }

        // Show webhook configuration status
        function showWebhookStatus(message, isSuccess) {
            const statusDiv = document.getElementById("webhookConfigStatus");
            statusDiv.style.display = "block";
            statusDiv.style.background = isSuccess 
                ? "rgba(63, 185, 80, 0.2)" 
                : "rgba(248, 81, 73, 0.2)";
            statusDiv.style.border = isSuccess 
                ? "1px solid var(--accent-green)" 
                : "1px solid var(--accent-red)";
            statusDiv.style.color = isSuccess ? "var(--accent-green)" : "var(--accent-red)";
            statusDiv.textContent = message;
        }

        // Update time stamps periodically
        setInterval(() => {
            if (selectedFailureId) {
                const failure = failures.find(f => f.id === selectedFailureId);
                if (failure) {
                    document.getElementById("detailTime").textContent = getTimeAgo(failure.timestamp);
                }
            }
            // Update time in sidebar cards
            document.querySelectorAll('.failure-card-time').forEach((el, index) => {
                if (failures[index]) {
                    el.textContent = getTimeAgo(failures[index].timestamp);
                }
            });
        }, 30000); // Every 30 seconds

        // Initialize on page load
        document.addEventListener("DOMContentLoaded", function() {
            initializeSignalR();

            // Configure marked.js options for better markdown rendering
            marked.setOptions({
                highlight: function(code, lang) {
                    if (lang && hljs.getLanguage(lang)) {
                        return hljs.highlight(code, { language: lang }).value;
                    }
                    return hljs.highlightAuto(code).value;
                },
                breaks: true,
                gfm: true
            });
        });
    </script>
</body>
</html>
